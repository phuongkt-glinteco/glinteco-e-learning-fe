# Application Config
PORT=5000
API_PREFIX=api/v1
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5435
DATABASE_USER=rampup_user
DATABASE_PASSWORD=rampup_password
DATABASE_NAME=rampup_db
# Schema is managed by TypeORM migrations; keep synchronize disabled.
DATABASE_SYNCHRONIZE=false

# Cache Configuration (Redis)
REDIS_HOST=localhost
REDIS_PORT=6380

# Auth Configuration
# Access token: short-lived, signs/verifies API access. JWT_EXPIRES_IN is in seconds.
JWT_SECRET=super-secret-jwt-key-for-ramp-up
JWT_EXPIRES_IN=900
# Refresh token: long-lived, rotated on every /auth/refresh. Use a DISTINCT secret
# from the access token. JWT_REFRESH_EXPIRES_IN is in seconds (default 7 days).
JWT_REFRESH_SECRET=super-secret-refresh-key-for-ramp-up
JWT_REFRESH_EXPIRES_IN=604800

# Google OAuth 2.0
# OAuth Client ID dùng làm `audience` khi xác thực ID Token.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Chỉ cho phép đăng nhập bằng email thuộc domain công ty (bỏ trống để cho phép mọi tài khoản Google đã xác thực).
ALLOWED_EMAIL_DOMAIN=glinteco.com
